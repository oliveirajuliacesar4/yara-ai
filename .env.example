OPENAI_API_KEY=coloque_sua_chave_aqui
OPENAI_MODEL=gpt-4.1-mini
PORT=3000
NODE_ENV=production
PUBLIC_APP_URL=https://yara-ai.com
ALLOWED_ORIGINS=https://yara-ai.com,https://www.yara-ai.com
ADMIN_TOKEN=gere_um_token_longo_e_secreto
DATABASE_URL=postgresql://usuario:senha@host:5432/yara_ai
PGSSLMODE=require

# Pagamentos reais exigem contas e credenciais dos provedores.
STRIPE_SECRET_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
ASAAS_API_KEY=

# Open Finance exige provedor credenciado/consentimento regulatório.
OPEN_FINANCE_PROVIDER_URL=
OPEN_FINANCE_CLIENT_ID=
OPEN_FINANCE_CLIENT_SECRET=
